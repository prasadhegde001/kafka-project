{
    "topic": "user-info-topic",
    "schema_type": "JSON",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "description": "Schema for User topic",
      "type": "object",
      "properties": {
        "user_id": {
            "type": "string",
            "description": "Unique order identifier"
          },
        "first_name": {
          "type": "string",
          "description": "Users First Name"
        },
        "last_name": {
          "type": "string",
          "description": "Users Last Name"
        },
        "age": {
          "type": "integer",
          "description": "Age of the user"
        },
        "city": {
          "type": "string",
          "description": "Users City"
        },
        "email": {
          "type": "string",
          "description": "Users Email"
        }
      },
      "required": ["user_id", "first_name", "last_name", "age", "city", "email"]
    }
  }